@startuml LearnOw_UC01_Authentication
' ============================================================
'  UC01 - AUTHENTICATION & USER MANAGEMENT
' ============================================================
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false

actor "Guest" as Guest #LightBlue
actor "Learner" as Learner #LightGreen
actor "Instructor" as Instructor #Orange
actor "Admin" as Admin #Tomato
actor "Email Service" as Email #LightGray

rectangle "Authentication & User Management" {
  usecase "UC-AUTH-01\nĐăng ký tài khoản" as UC01
  usecase "UC-AUTH-02\nĐăng nhập\n(Email/Password)" as UC02
  usecase "UC-AUTH-03\nĐăng nhập qua Google\nOAuth 2.0" as UC03
  usecase "UC-AUTH-04\nQuên mật khẩu" as UC04
  usecase "UC-AUTH-05\nĐăng xuất" as UC05
  usecase "UC-AUTH-06\nXác nhận email" as UC06
  usecase "UC-AUTH-07\nĐổi mật khẩu" as UC07
  usecase "UC-USER-01\nCập nhật hồ sơ\ncá nhân" as UC08
  usecase "UC-USER-02\nĐăng ký làm\ngiảng viên" as UC09
  usecase "UC-USER-03\nDuyệt yêu cầu\nđăng ký giảng viên" as UC10
  usecase "UC-USER-04\nQuản lý người dùng" as UC11
  usecase "UC-USER-05\nKhóa/Mở tài khoản" as UC12
  usecase "Gửi email xác nhận" as UC_SEND_EMAIL
}

Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04

Learner --> UC05
Learner --> UC07
Learner --> UC08
Learner --> UC09
Instructor --> UC08

Admin --> UC10
Admin --> UC11

UC01 ..> UC06 : <<include>>
UC06 ..> UC_SEND_EMAIL : <<include>>
UC04 ..> UC_SEND_EMAIL : <<include>>
UC11 ..> UC12 : <<include>>

UC_SEND_EMAIL --> Email

note right of UC01
  **Validation:**
  - Email hợp lệ, chưa tồn tại
  - Mật khẩu ≥ 8 ký tự
    (chữ hoa + thường + số)
  - Vai trò mặc định: Learner
end note

note right of UC02
  **Xử lý lỗi:**
  Sai mật khẩu 5 lần
  → Khóa 15 phút
end note

note right of UC09
  **Input:**
  - Lĩnh vực chuyên môn
  - Kinh nghiệm
  - Bằng cấp (tùy chọn)
  **Flow:** Pending → Approved/Rejected
end note

@enduml
