@startuml LearnOw_UseCase_Overview
' ============================================================
'  LEARNOW - USE CASE DIAGRAM (TỔNG QUAN)
'  Nền tảng bán khóa học trực tuyến
' ============================================================

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBackgroundColor #FEFECE
skinparam usecaseBorderColor #A80036
skinparam actorBorderColor #A80036
skinparam packageBorderColor #666666
skinparam arrowColor #333333
skinparam shadowing false

' --- ACTORS ---
actor "Guest\n(Khách)" as Guest #LightBlue
actor "Learner\n(Học viên)" as Learner #LightGreen
actor "Instructor\n(Giảng viên)" as Instructor #Orange
actor "Reviewer\n(Thẩm định viên)" as Reviewer #Plum
actor "Admin\n(Quản trị viên)" as Admin #Tomato

' --- Kế thừa vai trò ---
Guest <|-- Learner
Learner <|-- Instructor

' --- Hệ thống ngoài ---
actor "Payment Gateway\n(VNPay/MoMo)" as PG #LightGray
actor "Email Service" as Email #LightGray
actor "Cloud Storage\n(Video/File)" as Cloud #LightGray

' ============================================================
'  HỆ THỐNG LEARNOW
' ============================================================
rectangle "Hệ thống LearnOw" {

  ' --- 1. AUTHENTICATION ---
  package "Authentication" as auth_pkg {
    usecase "Đăng ký tài khoản" as UC_REGISTER
    usecase "Đăng nhập" as UC_LOGIN
    usecase "Đăng nhập qua Google" as UC_GOOGLE_LOGIN
    usecase "Quên mật khẩu" as UC_FORGOT_PW
    usecase "Đăng xuất" as UC_LOGOUT
    usecase "Xác nhận email" as UC_VERIFY_EMAIL
  }

  ' --- 2. DUYỆT KHÓA HỌC (PUBLIC) ---
  package "Duyệt & Tìm kiếm khóa học" as browse_pkg {
    usecase "Xem trang chủ" as UC_HOME
    usecase "Tìm kiếm khóa học" as UC_SEARCH
    usecase "Lọc khóa học" as UC_FILTER
    usecase "Xem chi tiết khóa học" as UC_COURSE_DETAIL
    usecase "Xem preview bài học miễn phí" as UC_PREVIEW
  }

  ' --- 3. MUA & HỌC ---
  package "Mua & Học khóa học" as learn_pkg {
    usecase "Thêm vào giỏ hàng" as UC_ADD_CART
    usecase "Áp dụng coupon" as UC_APPLY_COUPON
    usecase "Thanh toán khóa học" as UC_CHECKOUT
    usecase "Xem nội dung bài học" as UC_VIEW_LESSON
    usecase "Làm quiz" as UC_QUIZ
    usecase "Theo dõi tiến trình học" as UC_PROGRESS
    usecase "Nhận chứng chỉ hoàn thành" as UC_CERTIFICATE
    usecase "Yêu cầu hoàn tiền" as UC_REFUND
    usecase "Xem lịch sử mua hàng" as UC_ORDER_HISTORY
  }

  ' --- 4. ĐÁNH GIÁ ---
  package "Đánh giá khóa học" as rating_pkg {
    usecase "Đánh giá & nhận xét\nkhóa học" as UC_REVIEW_COURSE
    usecase "Sửa đánh giá" as UC_EDIT_REVIEW
  }

  ' --- 5. QUẢN LÝ HỒ SƠ ---
  package "Quản lý hồ sơ" as profile_pkg {
    usecase "Cập nhật hồ sơ cá nhân" as UC_UPDATE_PROFILE
    usecase "Đổi mật khẩu" as UC_CHANGE_PW
    usecase "Đăng ký làm giảng viên" as UC_REGISTER_INSTRUCTOR
  }

  ' --- 6. QUẢN LÝ KHÓA HỌC (INSTRUCTOR) ---
  package "Quản lý khóa học (Giảng viên)" as course_mgmt_pkg {
    usecase "Tạo khóa học mới" as UC_CREATE_COURSE
    usecase "Chỉnh sửa khóa học" as UC_EDIT_COURSE
    usecase "Quản lý Section & Lesson" as UC_MANAGE_CONTENT
    usecase "Upload video/tài liệu" as UC_UPLOAD
    usecase "Tạo quiz" as UC_CREATE_QUIZ
    usecase "Gửi khóa học đi duyệt" as UC_SUBMIT_REVIEW
    usecase "Quản lý coupon" as UC_MANAGE_COUPON
    usecase "Trả lời Q&A học viên" as UC_ANSWER_QA
    usecase "Xem dashboard\ngiảng viên" as UC_INSTRUCTOR_DASHBOARD
    usecase "Yêu cầu rút tiền\n(Payout)" as UC_REQUEST_PAYOUT
  }

  ' --- 7. THẨM ĐỊNH KHÓA HỌC (REVIEWER) ---
  package "Thẩm định khóa học" as review_pkg {
    usecase "Xem danh sách\nkhóa học chờ duyệt" as UC_LIST_PENDING
    usecase "Xem nội dung\nkhóa học cần duyệt" as UC_VIEW_REVIEW_CONTENT
    usecase "Đánh giá theo tiêu chí" as UC_EVALUATE
    usecase "Phê duyệt khóa học" as UC_APPROVE
    usecase "Từ chối khóa học" as UC_REJECT
    usecase "Yêu cầu chỉnh sửa" as UC_REQUEST_REVISION
    usecase "Xem lịch sử\nthẩm định" as UC_REVIEW_HISTORY
  }

  ' --- 8. QUẢN TRỊ HỆ THỐNG (ADMIN) ---
  package "Quản trị hệ thống" as admin_pkg {
    usecase "Quản lý người dùng" as UC_MANAGE_USERS
    usecase "Khóa/Mở tài khoản" as UC_LOCK_USER
    usecase "Duyệt yêu cầu\nđăng ký giảng viên" as UC_APPROVE_INSTRUCTOR
    usecase "Quản lý danh mục\nkhóa học" as UC_MANAGE_CATEGORIES
    usecase "Gỡ khóa học vi phạm" as UC_SUSPEND_COURSE
    usecase "Xử lý yêu cầu\nhoàn tiền" as UC_PROCESS_REFUND
    usecase "Cấu hình hệ thống" as UC_SYSTEM_CONFIG
    usecase "Xử lý payout\ncho giảng viên" as UC_PROCESS_PAYOUT
    usecase "Quản lý đánh giá\nvi phạm" as UC_MANAGE_REVIEWS
    usecase "Xem dashboard Admin" as UC_ADMIN_DASHBOARD
    usecase "Xem báo cáo\ndoanh thu" as UC_REVENUE_REPORT
  }

  ' --- 9. THÔNG BÁO ---
  package "Thông báo" as noti_pkg {
    usecase "Nhận thông báo\n(In-app)" as UC_RECEIVE_NOTI
    usecase "Quản lý cài đặt\nthông báo" as UC_NOTI_SETTINGS
  }
}

' ============================================================
'  QUAN HỆ ACTOR - USE CASE
' ============================================================

' --- Guest ---
Guest --> UC_REGISTER
Guest --> UC_LOGIN
Guest --> UC_GOOGLE_LOGIN
Guest --> UC_FORGOT_PW
Guest --> UC_HOME
Guest --> UC_SEARCH
Guest --> UC_COURSE_DETAIL

' --- Learner (kế thừa Guest, thêm các UC riêng) ---
Learner --> UC_LOGOUT
Learner --> UC_UPDATE_PROFILE
Learner --> UC_CHANGE_PW
Learner --> UC_ADD_CART
Learner --> UC_CHECKOUT
Learner --> UC_VIEW_LESSON
Learner --> UC_QUIZ
Learner --> UC_PROGRESS
Learner --> UC_CERTIFICATE
Learner --> UC_REFUND
Learner --> UC_ORDER_HISTORY
Learner --> UC_REVIEW_COURSE
Learner --> UC_EDIT_REVIEW
Learner --> UC_REGISTER_INSTRUCTOR
Learner --> UC_RECEIVE_NOTI
Learner --> UC_NOTI_SETTINGS

' --- Instructor (kế thừa Learner, thêm các UC riêng) ---
Instructor --> UC_CREATE_COURSE
Instructor --> UC_EDIT_COURSE
Instructor --> UC_MANAGE_CONTENT
Instructor --> UC_UPLOAD
Instructor --> UC_CREATE_QUIZ
Instructor --> UC_SUBMIT_REVIEW
Instructor --> UC_MANAGE_COUPON
Instructor --> UC_ANSWER_QA
Instructor --> UC_INSTRUCTOR_DASHBOARD
Instructor --> UC_REQUEST_PAYOUT

' --- Reviewer ---
Reviewer --> UC_LOGIN
Reviewer --> UC_LOGOUT
Reviewer --> UC_LIST_PENDING
Reviewer --> UC_VIEW_REVIEW_CONTENT
Reviewer --> UC_EVALUATE
Reviewer --> UC_APPROVE
Reviewer --> UC_REJECT
Reviewer --> UC_REQUEST_REVISION
Reviewer --> UC_REVIEW_HISTORY
Reviewer --> UC_UPDATE_PROFILE
Reviewer --> UC_RECEIVE_NOTI

' --- Admin ---
Admin --> UC_LOGIN
Admin --> UC_LOGOUT
Admin --> UC_MANAGE_USERS
Admin --> UC_LOCK_USER
Admin --> UC_APPROVE_INSTRUCTOR
Admin --> UC_MANAGE_CATEGORIES
Admin --> UC_SUSPEND_COURSE
Admin --> UC_PROCESS_REFUND
Admin --> UC_SYSTEM_CONFIG
Admin --> UC_PROCESS_PAYOUT
Admin --> UC_MANAGE_REVIEWS
Admin --> UC_ADMIN_DASHBOARD
Admin --> UC_REVENUE_REPORT
Admin --> UC_UPDATE_PROFILE
Admin --> UC_RECEIVE_NOTI

' ============================================================
'  QUAN HỆ GIỮA CÁC USE CASE
' ============================================================

' --- Include ---
UC_REGISTER ..> UC_VERIFY_EMAIL : <<include>>
UC_CHECKOUT ..> UC_APPLY_COUPON : <<extend>>
UC_SEARCH ..> UC_FILTER : <<extend>>
UC_COURSE_DETAIL ..> UC_PREVIEW : <<extend>>
UC_VIEW_LESSON ..> UC_PROGRESS : <<include>>
UC_MANAGE_CONTENT ..> UC_UPLOAD : <<include>>
UC_MANAGE_CONTENT ..> UC_CREATE_QUIZ : <<extend>>
UC_EVALUATE ..> UC_APPROVE : <<extend>>
UC_EVALUATE ..> UC_REJECT : <<extend>>
UC_EVALUATE ..> UC_REQUEST_REVISION : <<extend>>
UC_MANAGE_USERS ..> UC_LOCK_USER : <<include>>

' ============================================================
'  QUAN HỆ VỚI HỆ THỐNG NGOÀI
' ============================================================

UC_CHECKOUT --> PG
UC_PROCESS_REFUND --> PG
UC_PROCESS_PAYOUT --> PG
UC_VERIFY_EMAIL --> Email
UC_RECEIVE_NOTI --> Email
UC_UPLOAD --> Cloud
UC_VIEW_LESSON --> Cloud

@enduml
