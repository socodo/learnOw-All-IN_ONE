@startuml LearnOw_UC04_Learning
' ============================================================
'  UC04 - ENROLLMENT & LEARNING (HỌC VIÊN)
' ============================================================
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false

actor "Guest" as Guest #LightBlue
actor "Learner\n(Học viên)" as Learner #LightGreen
actor "Payment Gateway\n(VNPay/MoMo)" as PG #LightGray
actor "Cloud Storage" as Cloud #LightGray

rectangle "Tìm kiếm, Mua & Học khóa học" {

  package "Tìm kiếm & Duyệt" {
    usecase "UC-LEARN-01\nXem trang chủ" as UC01
    usecase "UC-LEARN-02\nTìm kiếm khóa học\n(Full-text search)" as UC02
    usecase "UC-LEARN-03\nLọc khóa học" as UC03
    usecase "UC-LEARN-04\nXem chi tiết\nkhóa học" as UC04
    usecase "UC-LEARN-05\nXem preview\nbài học miễn phí" as UC05
  }

  package "Mua khóa học" {
    usecase "UC-LEARN-06\nThêm vào giỏ hàng" as UC06
    usecase "UC-LEARN-07\nXem giỏ hàng" as UC07
    usecase "UC-LEARN-08\nÁp dụng mã\ngiảm giá (Coupon)" as UC08
    usecase "UC-LEARN-09\nThanh toán" as UC09
    usecase "UC-LEARN-10\nXem lịch sử\nmua hàng" as UC10
  }

  package "Học tập" {
    usecase "UC-LEARN-11\nXem video bài học" as UC11
    usecase "UC-LEARN-12\nĐọc bài viết" as UC12
    usecase "UC-LEARN-13\nLàm quiz" as UC13
    usecase "UC-LEARN-14\nTải tài liệu\nđính kèm" as UC14
    usecase "UC-LEARN-15\nGhi chú cá nhân" as UC15
    usecase "UC-LEARN-16\nTheo dõi tiến trình\nhọc tập" as UC16
    usecase "UC-LEARN-17\nNhận chứng chỉ\nhoàn thành" as UC17
  }

  package "Đánh giá & Hoàn tiền" {
    usecase "UC-LEARN-18\nĐánh giá &\nnhận xét khóa học" as UC18
    usecase "UC-LEARN-19\nSửa đánh giá" as UC19
    usecase "UC-LEARN-20\nYêu cầu hoàn tiền" as UC20
    usecase "UC-LEARN-21\nĐặt câu hỏi Q&A" as UC21
  }
}

Guest --> UC01
Guest --> UC02
Guest --> UC04

Learner --> UC01
Learner --> UC02
Learner --> UC04
Learner --> UC06
Learner --> UC07
Learner --> UC09
Learner --> UC10
Learner --> UC11
Learner --> UC12
Learner --> UC13
Learner --> UC14
Learner --> UC15
Learner --> UC16
Learner --> UC18
Learner --> UC19
Learner --> UC20
Learner --> UC21

UC02 ..> UC03 : <<extend>>
UC04 ..> UC05 : <<extend>>
UC09 ..> UC08 : <<extend>>
UC11 ..> UC16 : <<include>>
UC12 ..> UC16 : <<include>>
UC13 ..> UC16 : <<include>>
UC16 ..> UC17 : <<extend>>

UC09 --> PG
UC11 --> Cloud
UC14 --> Cloud

note right of UC02
  **Tìm kiếm theo:**
  - Tên khóa học
  - Mô tả
  - Tên giảng viên
  **Lọc theo:**
  Danh mục, Trình độ, Giá,
  Đánh giá, Ngôn ngữ
end note

note right of UC09
  **Phương thức thanh toán:**
  - Ví MoMo / ZaloPay
  - Chuyển khoản ngân hàng
  - Visa / Mastercard
  **Timeout:** 30 phút
end note

note right of UC11
  **Tính năng:**
  - Tốc độ: 0.5x - 2x
  - Ghi nhớ vị trí xem
  - Nhiều chất lượng:
    360p / 720p / 1080p
end note

note right of UC17
  **Điều kiện:**
  - 100% Lesson hoàn thành
  - Đạt điểm Quiz tối thiểu
  **Output:** PDF + mã xác thực
end note

note right of UC20
  **Điều kiện:**
  - Trong 7 ngày từ ngày mua
  - Tiến trình ≤ 20%
end note

note right of UC18
  **Điều kiện:**
  - Đã mua khóa học
  - Tiến trình ≥ 30%
  **Input:** 1-5 sao + nhận xét
end note

@enduml
