@startuml LearnOw_UC02_CourseManagement
' ============================================================
'  UC02 - COURSE MANAGEMENT (GIẢNG VIÊN)
' ============================================================
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false

actor "Instructor\n(Giảng viên)" as Instructor #Orange
actor "Cloud Storage" as Cloud #LightGray

rectangle "Quản lý khóa học (Giảng viên)" {

  package "Tạo & Chỉnh sửa" {
    usecase "UC-COURSE-01\nTạo khóa học mới" as UC01
    usecase "UC-COURSE-02\nChỉnh sửa thông tin\nkhóa học" as UC02
    usecase "UC-COURSE-03\nXóa khóa học (Draft)" as UC03
  }

  package "Quản lý nội dung" {
    usecase "UC-COURSE-04\nThêm/Sửa/Xóa Section" as UC04
    usecase "UC-COURSE-05\nThêm/Sửa/Xóa Lesson" as UC05
    usecase "UC-COURSE-06\nUpload video" as UC06
    usecase "UC-COURSE-07\nUpload tài liệu\nđính kèm" as UC07
    usecase "UC-COURSE-08\nTạo Quiz" as UC08
    usecase "UC-COURSE-09\nSắp xếp thứ tự\nSection/Lesson" as UC09
    usecase "UC-COURSE-10\nĐánh dấu Lesson\nmiễn phí (Preview)" as UC10
  }

  package "Xuất bản" {
    usecase "UC-COURSE-11\nGửi khóa học\nđi duyệt" as UC11
    usecase "UC-COURSE-12\nChỉnh sửa theo\nyêu cầu Reviewer" as UC12
    usecase "UC-COURSE-13\nCập nhật khóa học\nđã công khai" as UC13
  }

  package "Quản lý bán hàng" {
    usecase "UC-COURSE-14\nTạo/Quản lý Coupon" as UC14
    usecase "UC-COURSE-15\nĐặt giá khóa học" as UC15
    usecase "UC-COURSE-16\nTrả lời Q&A\nhọc viên" as UC16
  }

  package "Thống kê" {
    usecase "UC-COURSE-17\nXem dashboard\ngiảng viên" as UC17
    usecase "UC-COURSE-18\nXem báo cáo\ndoanh thu" as UC18
    usecase "UC-COURSE-19\nYêu cầu rút tiền\n(Payout)" as UC19
  }
}

Instructor --> UC01
Instructor --> UC02
Instructor --> UC03
Instructor --> UC04
Instructor --> UC05
Instructor --> UC09
Instructor --> UC10
Instructor --> UC11
Instructor --> UC12
Instructor --> UC13
Instructor --> UC14
Instructor --> UC15
Instructor --> UC16
Instructor --> UC17
Instructor --> UC18
Instructor --> UC19

UC05 ..> UC06 : <<extend>>
UC05 ..> UC07 : <<extend>>
UC05 ..> UC08 : <<extend>>
UC06 --> Cloud
UC07 --> Cloud

note right of UC01
  **Input bắt buộc:**
  - Tên (10-100 ký tự)
  - Mô tả ngắn (≤ 200 ký tự)
  - Mô tả chi tiết
  - Danh mục, Thumbnail, Giá
  - Trình độ, Ngôn ngữ
  **Trạng thái:** Draft
end note

note right of UC11
  **Điều kiện gửi duyệt:**
  - ≥ 5 Lesson
  - Tổng video ≥ 30 phút
  - Đầy đủ thông tin bắt buộc
  **Trạng thái:** Draft → Pending Review
end note

note right of UC13
  **Quy tắc:**
  - Thay đổi nhỏ: tự động cập nhật
  - Thay đổi lớn: cần duyệt lại
end note

note bottom of UC15
  Giá: 0 - 10.000.000 VNĐ
end note

@enduml
