@startuml LearnOw_UC05_Admin
' ============================================================
'  UC05 - ADMIN MANAGEMENT (QUẢN TRỊ VIÊN)
' ============================================================
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false

actor "Admin\n(Quản trị viên)" as Admin #Tomato
actor "Payment Gateway\n(VNPay/MoMo)" as PG #LightGray
actor "Email Service" as Email #LightGray

rectangle "Quản trị hệ thống" {

  package "Quản lý người dùng" {
    usecase "UC-ADMIN-01\nXem danh sách\nngười dùng" as UC01
    usecase "UC-ADMIN-02\nTìm kiếm &\nLọc người dùng" as UC02
    usecase "UC-ADMIN-03\nKhóa / Mở\ntài khoản" as UC03
    usecase "UC-ADMIN-04\nĐổi vai trò\nngười dùng" as UC04
    usecase "UC-ADMIN-05\nDuyệt yêu cầu\nđăng ký giảng viên" as UC05
  }

  package "Quản lý nội dung" {
    usecase "UC-ADMIN-06\nQuản lý danh mục\nkhóa học (CRUD)" as UC06
    usecase "UC-ADMIN-07\nXem tất cả\nkhóa học" as UC07
    usecase "UC-ADMIN-08\nGỡ khóa học\nvi phạm (Suspend)" as UC08
    usecase "UC-ADMIN-09\nQuản lý đánh giá\nvi phạm" as UC09
  }

  package "Tài chính" {
    usecase "UC-ADMIN-10\nXử lý yêu cầu\nhoàn tiền" as UC10
    usecase "UC-ADMIN-11\nXử lý Payout\ncho giảng viên" as UC11
    usecase "UC-ADMIN-12\nCấu hình tỷ lệ\nchia doanh thu" as UC12
    usecase "UC-ADMIN-13\nQuản lý Coupon\ntoàn hệ thống" as UC13
  }

  package "Báo cáo & Thống kê" {
    usecase "UC-ADMIN-14\nXem Dashboard\ntổng hợp" as UC14
    usecase "UC-ADMIN-15\nBáo cáo doanh thu\n(tháng/quý/năm)" as UC15
    usecase "UC-ADMIN-16\nThống kê người dùng\ntheo vai trò" as UC16
    usecase "UC-ADMIN-17\nTop khóa học\nbán chạy" as UC17
    usecase "UC-ADMIN-18\nTop giảng viên" as UC18
  }

  package "Cấu hình" {
    usecase "UC-ADMIN-19\nCấu hình hệ thống" as UC19
    usecase "UC-ADMIN-20\nQuản lý thông báo\nhệ thống" as UC20
    usecase "UC-ADMIN-21\nXử lý khiếu nại\n(Dispute)" as UC21
  }
}

Admin --> UC01
Admin --> UC02
Admin --> UC03
Admin --> UC04
Admin --> UC05
Admin --> UC06
Admin --> UC07
Admin --> UC08
Admin --> UC09
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21

UC10 --> PG
UC11 --> PG
UC05 --> Email
UC10 --> Email
UC08 --> Email

UC01 ..> UC02 : <<extend>>
UC14 ..> UC15 : <<include>>
UC14 ..> UC16 : <<include>>
UC14 ..> UC17 : <<include>>
UC14 ..> UC18 : <<include>>
UC19 ..> UC12 : <<include>>

note right of UC05
  **Xem xét:**
  - Thông tin chuyên môn
  - Kinh nghiệm
  - Bằng cấp
  **Quyết định:** Approved / Rejected
end note

note right of UC10
  **Điều kiện hoàn tiền:**
  - Trong 7 ngày kể từ mua
  - Tiến trình ≤ 20%
  **Thời gian xử lý:**
  5-10 ngày làm việc
end note

note right of UC11
  **Payout:**
  - Chu kỳ: hàng tháng (ngày 15)
  - Tối thiểu: 500.000 VNĐ
  - Tỷ lệ: Platform 30% - Instructor 70%
end note

note right of UC08
  **Suspend:**
  - Khóa học ẩn khỏi public
  - Học viên cũ vẫn truy cập được
  - Thông báo giảng viên
end note

@enduml
